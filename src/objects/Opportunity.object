    </fields>
    <fields>
        <fullName>Line_Of_Business__c</fullName>
        <externalId>false</externalId>
        <label>Line Of Business</label>
        <required>false</required>
        <trackFeedHistory>false</trackFeedHistory>
        <trackTrending>false</trackTrending>
        <type>Picklist</type>
        <valueSet>
            <valueSetDefinition>
                <sorted>false</sorted>
                <value>
                    <fullName>Employee Benefits</fullName>
                    <default>false</default>
                </value>
                <value>
                    <fullName>Bonds</fullName>
                    <default>false</default>
                </value>
                <value>
                    <fullName>Retirement</fullName>
                    <default>false</default>
                </value>
                <value>
                    <fullName>Personal Lines</fullName>
